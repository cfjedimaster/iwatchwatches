---
import { formatAbsoluteDate } from "../lib/format";

interface Props {
  title: string;
  url: string;
  synopsis: string | null;
  imageUrl: string | null;
  publishedAt: Date | string | null;
  feedName: string;
  feedUrl: string;
}

const { title, url, synopsis, imageUrl, publishedAt, feedName, feedUrl } = Astro.props;
---

<article class="featured">
  <a class="featured-media" href={url} target="_blank" rel="noopener noreferrer">
    {
      imageUrl ? (
        <img src={imageUrl} alt="" loading="eager" referrerpolicy="no-referrer" />
      ) : (
        <div aria-hidden="true" style="width:100%;height:100%;"></div>
      )
    }
  </a>
  <div class="featured-copy">
    <p class="eyebrow">Featured</p>
    <h1 class="featured-title">
      <a href={url} target="_blank" rel="noopener noreferrer">{title}</a>
    </h1>
    <div class="meta">
      <a class="source" href={feedUrl} target="_blank" rel="noopener noreferrer">{feedName}</a>
      {publishedAt && <span>{formatAbsoluteDate(publishedAt)}</span>}
    </div>
    {synopsis && <p class="synopsis">{synopsis}</p>}
  </div>
</article>
