---
import { pageHref, pageNumbers } from "../lib/pagination";

interface Props {
  currentPage: number;
  totalPages: number;
  hasPrev: boolean;
  hasNext: boolean;
}

const { currentPage, totalPages, hasPrev, hasNext } = Astro.props;
const pages = pageNumbers(currentPage, totalPages);
---

{
  totalPages > 1 && (
    <nav class="pagination" aria-label="Pagination">
      {hasPrev ? (
        <a href={pageHref(currentPage - 1)} rel="prev">
          Previous
        </a>
      ) : (
        <span class="disabled">Previous</span>
      )}

      {pages.map((page) => (
        <a href={pageHref(page)} aria-current={page === currentPage ? "page" : undefined}>
          {page}
        </a>
      ))}

      {hasNext ? (
        <a href={pageHref(currentPage + 1)} rel="next">
          Next
        </a>
      ) : (
        <span class="disabled">Next</span>
      )}
    </nav>
  )
}
